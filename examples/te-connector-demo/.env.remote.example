# Sitecore XM Cloud Environment Variables
# Copy to .env.local and fill in values

# Edge context ID from XM Cloud project
SITECORE_EDGE_CONTEXT_ID=
NEXT_PUBLIC_SITECORE_EDGE_CONTEXT_ID=

# Edge URL (defaults to production edge)
SITECORE_EDGE_URL=https://edge.sitecorecloud.io/api/graphql/v1
NEXT_PUBLIC_SITECORE_EDGE_URL=https://edge.sitecorecloud.io/api/graphql/v1

# Default site name as configured in XM Cloud
NEXT_PUBLIC_DEFAULT_SITE_NAME=nxp

# Default language
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

# JSS editing secret for Sitecore Pages integration
SITECORE_EDITING_SECRET=

# API key for local development (optional)
NEXT_PUBLIC_SITECORE_API_KEY=
NEXT_PUBLIC_SITECORE_API_HOST=

# OrderCloud API base URL (backend proxy)
NEXT_PUBLIC_ORDERCLOUD_API_URL=
